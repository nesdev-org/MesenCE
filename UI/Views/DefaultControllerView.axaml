<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Mesen.ViewModels"
	xmlns:l="using:Mesen.Localization"
	xmlns:c="using:Mesen.Controls"
	xmlns:cfg="using:Mesen.Config"
	mc:Ignorable="d" d:DesignWidth="610" d:DesignHeight="230"
	x:Name="root"
	x:DataType="vm:KeyMappingViewModel"
	x:Class="Mesen.Views.DefaultControllerView"
>
	<Design.DataContext>
		<vm:KeyMappingViewModel />
	</Design.DataContext>

	<Border
		MaxWidth="{Binding MaxWidth, ElementName=root}"
		MaxHeight="300"
		BorderBrush="{StaticResource MesenGrayBorderColor}"
		BorderThickness="1"
		Margin="{Binding Margin, ElementName=root}"
	>
		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding CustomKeys}">
				<ItemsControl.Styles>
					<Style Selector="ContentPresenter > Border">
						<Setter Property="BorderThickness" Value="0 0 0 1" />
					</Style>
					<Style Selector="ContentPresenter:nth-last-child(1) > Border">
						<Setter Property="BorderThickness" Value="0" />
					</Style>
				</ItemsControl.Styles>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="{StaticResource MesenGrayBorderColor}">
							<Grid ColumnDefinitions="3*, 1*" Margin="5 0 5 0">
								<TextBlock Grid.Column="0" Text="{Binding Name}" />
								<c:KeyBindingButton Grid.Column="1" KeyBinding="{Binding KeyMapping}" HorizontalAlignment="Stretch" />
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Border>
</UserControl>
